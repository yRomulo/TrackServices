{
  "Persistence": {
    "Provider": "InMemory",
    "DatabaseName": "TrackServicesDev"
  },
  "ConnectionStrings": {
    "TrackServicesDb": "Server=(localdb)\\MSSQLLocalDB;Database=TrackServices;Trusted_Connection=True;TrustServerCertificate=True"
  },
